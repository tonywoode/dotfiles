  prefix_rule(pattern=["sudo"], decision="deny")
  prefix_rule(pattern=["/bin/rm"], decision="deny")
  prefix_rule(pattern=["/usr/bin/rm"], decision="deny")
  prefix_rule(pattern=["rm", "-rf", "/"], decision="deny")
  prefix_rule(pattern=["rm", "-rf", "~"], decision="deny")
  prefix_rule(pattern=["git", "clean", "-fdx"], decision="deny")
  prefix_rule(pattern=["git", "reset", "--hard"], decision="deny")
  prefix_rule(pattern=["dd"], decision="deny")
  prefix_rule(pattern=["mkfs"], decision="deny")
  prefix_rule(pattern=["diskutil"], decision="deny")
  prefix_rule(pattern=["mount"], decision="deny")
  prefix_rule(pattern=["umount"], decision="deny")

  prefix_rule(pattern=["ls"], decision="allow")
  prefix_rule(pattern=["cat"], decision="allow")
  prefix_rule(pattern=["rg"], decision="allow")
  prefix_rule(pattern=["sed"], decision="allow")
  prefix_rule(pattern=["awk"], decision="allow")
  prefix_rule(pattern=["lsof"], decision="allow")
  prefix_rule(pattern=["git", "status"], decision="allow")
  prefix_rule(pattern=["git", "diff"], decision="allow")
  prefix_rule(pattern=["git", "log"], decision="allow")


prefix_rule(pattern=["npx", "playwright", "test"], decision="allow")
prefix_rule(pattern=["node", "--loader", "tsx"], decision="allow")
prefix_rule(pattern=["node", "--import", "tsx"], decision="allow")
prefix_rule(pattern=["npx", "pm2", "logs"], decision="allow")
prefix_rule(pattern=["ps"], decision="allow")
prefix_rule(pattern=["top"], decision="allow")
prefix_rule(pattern=["pgrep"], decision="allow")
prefix_rule(pattern=["systemextensionsctl", "list"], decision="allow")
prefix_rule(pattern=["/usr/bin/log", "show"], decision="allow")
